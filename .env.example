# Database
DATABASE_URL=postgresql://user:password@localhost:5432/servio

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin Bank Info
ADMIN_BANK_ACCOUNT=your-bank-account
ADMIN_BANK_IBAN=your-iban
ADMIN_BANK_NAME=your-bank-name
ADMIN_BANK_ACCOUNT_HOLDER=your-name
NEXT_PUBLIC_ADMIN_BANK_ACCOUNT=your-bank-account
NEXT_PUBLIC_ADMIN_BANK_IBAN=your-iban
NEXT_PUBLIC_ADMIN_BANK_NAME=your-bank-name
NEXT_PUBLIC_ADMIN_BANK_ACCOUNT_HOLDER=your-name

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Servio

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Optional
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_SUPABASE_REALTIME_URL=
